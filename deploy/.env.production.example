APP_NAME="ePages Webhooks"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://SEU_DOMINIO.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# Database - MySQL recomendado para produção
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=epages_webhooks
DB_USERNAME=epages_user
DB_PASSWORD=SUA_PASSWORD_SEGURA

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=.SEU_DOMINIO.com

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

# Email - SMTP real
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailgun.org
MAIL_PORT=587
MAIL_USERNAME=postmaster@SEU_DOMINIO.com
MAIL_PASSWORD=SUA_PASSWORD_SMTP
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@SEU_DOMINIO.com"
MAIL_FROM_NAME="${APP_NAME}"

# ePages Webhook Configuration
WEBHOOK_URL=
POLL_SKIP_HISTORICAL_ORDERS=true
WEBHOOK_LOG_RETENTION_DAYS=30
WEBHOOK_DELAY_MS=100

# ePages App Store Integration
EPAGES_CLIENT_ID=SEU_CLIENT_ID
EPAGES_CLIENT_SECRET=SEU_CLIENT_SECRET
EPAGES_REDIRECT_URI="${APP_URL}/epages/callback"
EPAGES_SCOPES=read_orders
EPAGES_VERIFY_SIGNATURE=true
EPAGES_ENCRYPT_TOKENS=true

# Stripe PRODUCTION Keys
STRIPE_KEY=pk_live_XXXXX
STRIPE_SECRET=sk_live_XXXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXXX

# Stripe Price IDs (production)
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_YEARLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_BUSINESS_MONTHLY=
STRIPE_PRICE_BUSINESS_YEARLY=

# Cashier Configuration
CASHIER_CURRENCY=eur
CASHIER_CURRENCY_LOCALE=pt_PT
