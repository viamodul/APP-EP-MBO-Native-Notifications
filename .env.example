APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ePages Webhook Configuration
WEBHOOK_URL=http://localhost:3000/webhook

# On first poll (when last_processed_order_date is NULL), only get orders from now
# Set to true for production to avoid processing historical orders
POLL_SKIP_HISTORICAL_ORDERS=false

# Webhook log retention (days) - logs older than this are auto-deleted
WEBHOOK_LOG_RETENTION_DAYS=20

# Delay between webhooks to the same endpoint (milliseconds)
# Prevents overloading destination servers. Set to 0 to disable.
WEBHOOK_DELAY_MS=100

# ePages App Store Integration
# Get these from your ePages developer account
EPAGES_CLIENT_ID=
EPAGES_CLIENT_SECRET=
EPAGES_REDIRECT_URI="${APP_URL}/epages/callback"
EPAGES_SCOPES=read_orders
EPAGES_VERIFY_SIGNATURE=true
EPAGES_ENCRYPT_TOKENS=true

# Stripe Configuration (Laravel Cashier)
STRIPE_KEY=pk_test_your_publishable_key
STRIPE_SECRET=sk_test_your_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret

# Stripe Price IDs (generated by php artisan stripe:setup-products)
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_YEARLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_BUSINESS_MONTHLY=
STRIPE_PRICE_BUSINESS_YEARLY=

# Cashier Configuration
CASHIER_CURRENCY=eur
CASHIER_CURRENCY_LOCALE=pt_PT
