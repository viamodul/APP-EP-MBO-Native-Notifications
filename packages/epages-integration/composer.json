{
    "name": "viamodul/epages-integration",
    "description": "ePages Now API integration package for Laravel",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "epages",
        "ecommerce",
        "api",
        "integration"
    ],
    "authors": [
        {
            "name": "Your Name",
            "email": "your.email@example.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0",
        "pestphp/pest": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "EpagesIntegration\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "EpagesIntegration\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "EpagesIntegration\\EpagesServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}